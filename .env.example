# ── Neo4j Graph Database (optional) ──────────────────────────────────────────
# Only required if using the Neo4j backend (graph/connection.py)
# The dashboard works without Neo4j using the in-memory NetworkX backend.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── Model paths (override defaults) ──────────────────────────────────────────
# MODEL_PATH=./gnn_model.pt
# DATASET_PATH=./gnn_dataset.pt
